# ——— Local development (plain `next dev` without wrangler) ———
# Fallback SQLite database. When Cloudflare bindings are available (deployed
# worker, `wrangler dev`, or the OpenNext dev bridge) the app uses D1 instead.
DATABASE_URL="file:./dev.db"

# ——— Authentication ———
# Set a password to gate the whole app behind a login screen.
# In production set it as a Worker secret instead:  npx wrangler secret put APP_PASSWORD
# Leave unset for an open (local-only) instance.
# APP_PASSWORD="choose-a-strong-password"

# ——— AI (optional server defaults) ———
# Users normally enter their own key in Settings (BYO-key). Optionally set a
# server default to make generation live out of the box:
# QUIRE_DEFAULT_AI_PROVIDER="openai"
# QUIRE_DEFAULT_AI_MODEL="gpt-4o-mini"
# QUIRE_DEFAULT_AI_KEY=""
# QUIRE_DEFAULT_AI_BASEURL=""
