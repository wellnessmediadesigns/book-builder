# Database — SQLite for local dev. Swap to a Postgres URL for production
# (and change datasource provider to "postgresql" in prisma/schema.prisma).
DATABASE_URL="file:./dev.db"

# AI keys are NOT required here — users enter their own key in Settings (BYO-key).
# Optionally set a server default to make generation live out of the box:
# QUIRE_DEFAULT_AI_PROVIDER="openai"
# QUIRE_DEFAULT_AI_MODEL="gpt-4o-mini"
# QUIRE_DEFAULT_AI_KEY=""
# QUIRE_DEFAULT_AI_BASEURL=""
